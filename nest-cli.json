{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": false,
    "assets": [
      {
        "include": "src/modules/mail/templates/**/*.hbs",
        "outDir": "dist/src/modules/mail"
      }
    ]
  }
}
